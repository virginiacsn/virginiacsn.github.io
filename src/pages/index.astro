---
import { getCollection } from "astro:content";
import Container from "@components/Container.astro";
import PageLayout from "@layouts/PageLayout.astro";
import ProjectCard from "@components/ProjectCard.astro";
import Link from "@components/Link.astro";
import { SITE, HOME, SOCIALS } from "@consts";

const emailEncoded = Buffer.from(SITE.EMAIL).toString("base64");

const projects = (await getCollection("projects"))
  .filter((project) => !project.data.draft && project.data.featured)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<PageLayout title={HOME.TITLE} description={HOME.DESCRIPTION}>
  <Container>
    <div class="space-y-16">
      <section>
        <div class="animate flex items-center justify-center gap-12 mb-6">
          <img
            src="/profile.png"
            alt="Virginia Casasnovas"
            class="w-40 h-40 rounded-full object-cover flex-shrink-0 ring-1 ring-offset-4 ring-offset-white dark:ring-offset-gray-800 ring-gray-500 dark:ring-white"
          />
          <div class="flex flex-col gap-3">
            <h4 class="font-semibold text-xl text-black dark:text-white leading-none">
              Hi, I'm Virginia!
            </h4>
            <!-- Title placeholder -->
            <p class="text-lg text-gray-500 dark:text-gray-400">
              Neuroscience researcher
            </p>
            <!-- Tags placeholder -->
            <div class="flex flex-wrap gap-2">
              <span
                class="px-3 py-1 rounded-full text-sm bg-gray-200 dark:bg-gray-700 text-gray-600 dark:text-gray-300"
                >movement control</span
              >
              <span
                class="px-3 py-1 rounded-full text-sm bg-gray-200 dark:bg-gray-700 text-gray-600 dark:text-gray-300"
                >neural dynamics</span
              >
              <span
                class="px-3 py-1 rounded-full text-sm bg-gray-200 dark:bg-gray-700 text-gray-600 dark:text-gray-300"
                >BCIs</span
              >
            </div>
          </div>
        </div>
      </section>

      <section class="animate space-y-6">
        <h5 class="font-semibold text-lg text-black dark:text-white">About</h5>
        <article class="space-y-4">
          <p class="animate">
            I'm a neuroscience researcher, biomedical engineer, and data
            scientist. My research has focused on understanding how the brain
            controls movement, aiming to drive the development of better
            solutions for patients with motor disabilities. After living in
            different countries across Europe, and the US, I'm now based in
            Toronto, Canada.
          </p>
          <p class="animate">
            I completed my
            <Link
              href="https://ediss.uni-goettingen.de/handle/11858/15872?locale-attribute=en"
              aria-label="Astro Nano on Github"
              external>PhD</Link
            >
            in Systems Neuroscience at the
            <Link
              href="https://www.dpz.eu/en/cognitive-neuroscience-unit"
              aria-label="Astro Nano on Github"
              external>German Primate Center</Link
            >, where I studied the effect of arm sensory uncertainty on how we
            control our movements and learn new ones. Before that, I worked as a
            research assistant at the
            <Link
              href="https://www.fchampalimaud.org/research/groups/carey"
              aria-label="Astro Nano on Github"
              external>Champalimaud Foundation</Link
            >, where I explored molecular neuromodulation techniques and the
            cerebellum's role in locomotion. Even longer ago, I trained as a
            biomedical engineer at <Link
              href="https://www.uc3m.es/bachelor-degree/biomedical"
              aria-label="Astro Nano on Github"
              external>Universidad Carlos III de Madrid</Link
            > and
            <Link
              href="https://www.tudelft.nl/en/me/about/departments/biomechanical-engineering"
              aria-label="Astro Nano on Github"
              external>Delft University of Technology</Link
            >, including an internship at <Link
              href="https://miller-limblab.squarespace.com/"
              aria-label="Astro Nano on Github"
              external>Northwestern University</Link
            >.
          </p>
          <p class="animate">
            <span class="font-sans italic">What's next?</span> I'm interested in moving
            into translational work within neurotechnology, wearables, and digital
            health. I'm driven by having a positive impact on people's health and
            contributing to the technology that makes that possible.
          </p>
          <p class="animate"></p>
        </article>

        <section class="animate space-y-6">
          <div class="flex flex-wrap gap-y-2 items-center justify-between">
            <h5 class="font-semibold text-lg text-black dark:text-white">
              Featured projects
            </h5>
            <Link href="/projects"> See all projects </Link>
          </div>
          <ul class="grid grid-cols-1 sm:grid-cols-3 gap-4" style="grid-auto-rows: 1fr;">
            {
              projects.map((project) => (
                <li class="h-full">
                  <ProjectCard entry={project} />
                </li>
              ))
            }
          </ul>
        </section>

        <section class="animate space-y-4">
          <h5 class="font-semibold text-lg text-black dark:text-white">
            Let's Connect
          </h5>
          <article>
            <p>
              If you'd like to get in touch, feel free to reach out on{" "}
              <Link
                href={SOCIALS.find((s) => s.NAME === "linkedin")!.HREF}
                external
                aria-label={`${SITE.NAME} on LinkedIn`}
              >
                LinkedIn</Link
              > or send me an <span class="js-email-link"></span>. I'm happy to
              chat!
            </p>
          </article>
        </section>
      </section>
    </div>
    <script is:inline define:vars={{ emailEncoded }}>
      document.addEventListener("DOMContentLoaded", function () {
        const email = atob(emailEncoded);
        document.querySelectorAll(".js-email-link").forEach(function (el) {
          const a = document.createElement("a");
          a.href = "mailto:" + email;
          a.textContent = "email";
          a.className =
            "inline-block underline underline-offset-2 decoration-black/15 dark:decoration-white/30 hover:decoration-black/25 hover:dark:decoration-white/50 text-current hover:text-black hover:dark:text-white transition-colors duration-300 ease-in-out";
          el.replaceWith(a);
        });
      });
    </script>
  </Container>
</PageLayout>
