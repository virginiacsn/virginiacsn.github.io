---
import { getCollection } from "astro:content";
import PageLayout from "@layouts/PageLayout.astro";
import Container from "@components/Container.astro";
import { dateRange } from "@lib/utils";
import { CV, SITE, SOCIALS } from "@consts";
import Link from "@components/Link.astro";

const collection = (await getCollection("work")).sort(
  (a, b) =>
    new Date(b.data.dateStart).valueOf() - new Date(a.data.dateStart).valueOf(),
);

const work = await Promise.all(
  collection.map(async (item) => {
    const { Content } = await item.render();
    return { ...item, Content };
  }),
);
---

<PageLayout title={CV.TITLE} description={CV.DESCRIPTION}>
  <Container>
    <div class="animate space-y-8 font-serif [&_strong]:font-sans">
      <section class="space-y-1">
        <h1 class="font-sans font-semibold text-xl text-black dark:text-white">
          {SITE.NAME}
        </h1>
        <div class="flex flex-wrap gap-x-4 gap-y-1">
          {
            SOCIALS.map((social) => (
              <Link href={social.HREF} external aria-label={social.NAME}>
                {social.NAME.charAt(0).toUpperCase() + social.NAME.slice(1)}
              </Link>
            ))
          }
        </div>
      </section>

      <section class="space-y-3">
        <h2
          class="font-sans font-semibold text-black dark:text-white border-b border-black dark:border-white pb-1"
        >
          Education
        </h2>
        <div class="space-y-1">
          <p>
            <strong>PhD in Systems Neuroscience</strong>, Georg-August
            University of Göttingen, Germany (2024)
          </p>
          <p>
            <strong>MSc in Biomedical Engineering</strong>, Delft University of
            Technology, the Netherlands (2018)
          </p>
          <p>
            <strong>BSc in Biomedical Engineering</strong>, Universidad Carlos
            III de Madrid, Spain (2016)
          </p>
        </div>
      </section>

      <section class="space-y-3">
        <h2
          class="font-sans font-semibold text-black dark:text-white border-b border-black dark:border-white pb-1"
        >
          Skills
        </h2>
        <div class="space-y-3">
          <p>
            <strong>Research expertise:</strong> Electrophysiology (multi-channel
            neural spiking, EMG), motion-tracking (kinematics, kinetics), BCIs, closed-loop
            data collection systems
          </p>
          <p>
            <strong>Quantitative methods:</strong> Signal processing, time-series
            analysis, feature engineering, machine learning (supervised, unsupervised),
            model evaluation, statistical modelling and inference
          </p>
          <p>
            <strong>Programming languages &amp; tools:</strong>
            Python, MATLAB, C++, Git, SQL
          </p>
        </div>
      </section>

      <section class="space-y-4">
        <h2
          class="font-sans font-semibold text-black dark:text-white border-b border-black dark:border-white pb-1"
        >
          Experience
        </h2>
        <ul class="space-y-6">
          {
            work.map((entry) => (
              <li>
                <div class="flex justify-between gap-4">
                  <span class="font-sans font-bold text-black dark:text-white">
                    {entry.data.role}
                  </span>
                  <span class="font-sans text-black dark:text-white shrink-0">
                    {dateRange(entry.data.dateStart, entry.data.dateEnd)}
                  </span>
                </div>
                <div class="font-sans text-black dark:text-white">
                  <span class="font-bold">{entry.data.company}</span>{entry.data.location ? `, ${entry.data.location}` : ""}
                </div>
                <article class="[&>ul]:mt-1 [&>ul]:space-y-0.5 [&>ul]:list-disc [&>ul]:pl-4 [&>ul>li]:my-0 [&>p:first-child]:mt-1">
                  <entry.Content />
                </article>
              </li>
            ))
          }
        </ul>
      </section>

      <section class="space-y-3">
        <h2
          class="font-sans font-semibold text-black dark:text-white border-b border-black dark:border-white pb-1"
        >
          Publications
        </h2>
        <ul class="space-y-4">
          <li>
            LK Amann*, <strong>V Casasnovas</strong>*, A Gail. Visual target and
            task-critical feedback uncertainty impair different stages of reach
            planning in motor cortex. <em>Nature Communications</em> 16(1), 3372 (2025)
            [<a
              class="font-sans underline underline-offset-2 decoration-black/15 dark:decoration-white/30 hover:decoration-black/25 hover:dark:decoration-white/50 transition-colors duration-300 ease-in-out"
              href="https://www.nature.com/articles/s41467-025-58738-x"
              target="_blank">Link</a
            >]
          </li>
          <li>
            LK Amann, <strong>V Casasnovas</strong>, J Hainke, A Gail.
            Optimality of multisensory integration while compensating for
            uncertain visual target information with artificial vibrotactile
            cues during reach planning. <em
              >Journal of NeuroEngineering and Rehabilitation</em
            >
            21(1), 155 (2024) [<a
              class="font-sans underline underline-offset-2 decoration-black/15 dark:decoration-white/30 hover:decoration-black/25 hover:dark:decoration-white/50 transition-colors duration-300 ease-in-out"
              href="https://link.springer.com/article/10.1186/s12984-024-01448-0"
              target="_blank">Link</a
            >]
          </li>
          <li>
            <strong>V Casasnovas</strong>, LK Amann, GL Haas, A Gail.
            Task-relevant visual feedback uncertainty attenuates visuomotor
            adaptation. <em>Journal of Neurophysiology</em> 132(3), 879–889 (2024)
            [<a
              class="font-sans underline underline-offset-2 decoration-black/15 dark:decoration-white/30 hover:decoration-black/25 hover:dark:decoration-white/50 transition-colors duration-300 ease-in-out"
              href="https://journals.physiology.org/doi/full/10.1152/jn.00180.2024"
              target="_blank">Link</a
            >]
          </li>
        </ul>
        <p class="text-sm">* Equal contribution</p>
      </section>
    </div>
  </Container>
</PageLayout>
